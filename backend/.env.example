# Chatita Mail v3.0 — Environment Variables
# Copy to .env and fill with real values. NEVER commit .env.

# ── Server ──────────────────────────────────────────────
ENVIRONMENT=development
PORT=8000
SECRET_KEY=change-me-in-production

# ── Database ────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://manuelcadena@localhost:5432/chatita_mail
DATABASE_URL_SYNC=postgresql://manuelcadena@localhost:5432/chatita_mail
REDIS_URL=redis://localhost:6379/0

# ── AION Brain (MCP server, already deployed) ───────────
# Mode: http (recommended) or stdio
AION_MODE=http
AION_BRAIN_URL=http://localhost:3100
AION_BRAIN_MCP_PATH=/opt/aion-brain/mcp-server.js
AION_TIMEOUT_SECONDS=60
AION_ALLOW_FALLBACK=true

# ── Email Accounts ──────────────────────────────────────
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
ICLOUD_USERNAME=
ICLOUD_APP_PASSWORD=

# ── Google Workspace (Gmail via Service Account + Domain-Wide Delegation) ──
# Path to the service-account JSON key. Reuses Chatita's existing SA.
GOOGLE_SERVICE_ACCOUNT_JSON=/Users/manuelcadena/chatita-local/chatita-service-account.json
# Mailbox to impersonate via DWD (Manny's primary inbox)
GMAIL_IMPERSONATE_SUBJECT=jose@manuelcadena.com

# ── Communication (Telegram notifications) ──────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Classification thresholds ───────────────────────────
LEXICAL_CONFIDENCE_THRESHOLD=0.90
MIN_CLASSIFICATION_ACCURACY=0.92
PHISHING_QUARANTINE_THRESHOLD=70
PHISHING_BLOCK_THRESHOLD=90

# ── Logging ─────────────────────────────────────────────
LOG_LEVEL=INFO
